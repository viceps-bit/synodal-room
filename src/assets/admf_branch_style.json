{
  "layers": [
    {
      "id": "admf_branch_points",
      "type": "circle",
      "source": "admf-hi-branch-source",
      "source-layer": "admfhibranch",
      "filter": [
        "all"
      ],
      "layout": {
        "circle-sort-key": 10
      },
      "paint": {
        "circle-color": "rgba(252, 222, 2, 1)",
        "circle-blur": 0.1,
        "circle-opacity": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          0,
          0.8,
          10,
          1
        ],
        "circle-stroke-color": [
          "case",
          [
            "==",
            [
              "get",
              "branchType"
            ],
            "Cabang"
          ],
          "#643B0D",
          [
            "==",
            [
              "get",
              "branchType"
            ],
            "Satellite"
          ],
          "#643B0D",
          [
            "==",
            [
              "get",
              "companyCode"
            ],
            "ADMF_HI"
          ],
          "#214284",
          "#000000"
        ],
        "circle-radius": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          0,
          [
            "case",
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Cabang"
            ],
            1,
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Satellite"
            ],
            1,
            1
          ],
          5,
          [
            "case",
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Cabang"
            ],
            3,
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Satellite"
            ],
            2,
            3
          ],
          9,
          [
            "case",
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Cabang"
            ],
            6,
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Satellite"
            ],
            4,
            6
          ],
          14,
          [
            "case",
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Cabang"
            ],
            8,
            [
              "==",
              [
                "get",
                "branchType"
              ],
              "Satellite"
            ],
            6,
            8
          ]
        ],
        "circle-stroke-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          0,
          0.2,
          10,
          3
        ]
      }
    },
    {
      "id": "admf_branch_syariah",
      "type": "symbol",
      "source": "admf-hi-branch-source",
      "source-layer": "admfhibranch",
      "minzoom": 9,
      "filter": [
        "any",
        [
          "==",
          "HIisSyariah",
          true
        ],
        [
          "==",
          "ADMFCategorySyariah",
          "Konvensional & Syariah"
        ],
        [
          "==",
          "ADMFCategorySyariah",
          "Syariah"
        ]
      ],
      "layout": {
        "icon-image": "religious_muslim",
        "symbol-placement": "point",
        "text-size": 10,
        "icon-size": 0.5,
        "icon-offset": [
          0,
          0
        ],
        "icon-allow-overlap": true
      },
      "paint": {
        "icon-opacity": 0.8
      }
    },
    {
      "id": "admf_branch_car",
      "type": "symbol",
      "source": "admf-hi-branch-source",
      "source-layer": "admfhibranch",
      "minzoom": 9,
      "layout": {
        "icon-image": [
          "case",
          [
            "in",
            [
              "get",
              "ADMFCategoryMIX_MCY_CAR"
            ],
            "CAR"
          ],
          "car",
          ""
        ],
        "text-anchor": "center",
        "text-field": [
          "get",
          "name"
        ],
        "text-offset": [
          0,
          1.5
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          0,
          6,
          14,
          12
        ],
        "text-line-height": 0.8,
        "text-justify": "center",
        "text-padding": 10,
        "text-allow-overlap": false,
        "text-overlap": "never",
        "text-max-width": 8,
        "icon-size": 0.7,
        "icon-anchor": "bottom",
        "icon-offset": [
          0,
          -10
        ]
      },
      "paint": {
        "text-halo-color": "rgba(255, 255, 255, 1)",
        "text-halo-width": 1,
        "text-halo-blur": 0.5
      }
    },
    {
      "id": "admf_branch_icon",
      "type": "symbol",
      "source": "admf-hi-branch-source",
      "source-layer": "admfhibranch"
    }
  ]
}